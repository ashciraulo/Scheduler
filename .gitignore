# Dependencies
node_modules/
**/node_modules/

# Build output (regenerated by `npm run build`; the deployable lives in offline-package/)
dist/
**/dist/
dist-ssr/

# Runtime shared-data store written by the offline-package server
offline-package/scheduler/scheduler-data.json
offline-package/scheduler/scheduler-data.json.tmp
**/__pycache__/

# Local env files
*.local
.env
.env.*
!.env.example

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.sw?

# Logs
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Sensitive: never commit real WIP exports or imported job data
*.xlsx
*.xls
scheduler-jobs-*.json
wip-review-*.json
